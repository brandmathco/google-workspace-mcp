# --- OAuth (personal Gmail / Google account) ---
# Create a Desktop OAuth client in Google Cloud Console:
# https://console.cloud.google.com/apis/credentials
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://127.0.0.1:3847/oauth2callback

# Optional: set after running `npm run authorize`
GOOGLE_REFRESH_TOKEN=

# Required for `npm run authorize` and GET /authorize on a remote host
# AUTHORIZE_HASH_KEY=

# Token file path (default: ~/.config/google-workspace-mcp/token.json)
# GOOGLE_TOKEN_PATH=

# --- Service account (Google Workspace domain-wide delegation) ---
# GOOGLE_SERVICE_ACCOUNT={"type":"service_account","client_email":"...","private_key":"..."}
# GOOGLE_WORKSPACE_USER_EMAIL=you@yourdomain.com

# Default Google Tasks list title when none is specified
GOOGLE_TASKS_DEFAULT_LIST=Action items

# --- Remote MCP (Fly.io or any HTTPS host) ---
# Required — protect the /mcp endpoint
# MCP_API_KEY=
# Remote OAuth callback (add the same URL in Google Cloud Console):
# GOOGLE_OAUTH_REDIRECT_URI=https://your-app.fly.dev/oauth2callback
# Start OAuth remotely (hash key required):
# GET https://your-app.fly.dev/authorize?hashKey=YOUR_AUTHORIZE_HASH_KEY
# HOST=0.0.0.0
# PORT=8080
# MCP_ALLOWED_HOSTS=your-app.fly.dev
